---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        <style is:global>
            body {
                font-family: system-ui, -apple-system, sans-serif;
                margin: 0;
                padding: 0;
                background: #fdfdfd;
                color: #333;
                line-height: 1.6;
            }
            main {
                max-width: 800px;
                margin: 0 auto;
                padding: 2rem;
            }
            a {
                color: #0066cc;
                text-decoration: none;
            }
            a:hover {
                text-decoration: underline;
            }
            code {
                background: #f4f4f4;
                padding: 0.2em 0.4em;
                border-radius: 4px;
                font-size: 0.9em;
            }
        </style>
	</head>
	<body>
        <header style="border-bottom: 1px solid #eee; background: #fff; position: sticky; top: 0; z-index: 10;">
            <div style="max-width: 800px; margin: 0 auto; padding: 1rem 2rem;">
                <div style="font-weight: bold; font-size: 1.2rem; margin-bottom: 0.5rem;">Knowledge Stack Portal</div>
                <nav style="display: flex; gap: 1.5rem;">
                    <a href="/" style={`text-decoration: none; padding-bottom: 0.5rem; ${Astro.url.pathname === '/' || Astro.url.pathname.startsWith('/articles') ? 'border-bottom: 2px solid #0066cc; color: #0066cc; font-weight: bold;' : 'color: #666;'}`}>
                        Articles
                    </a>
                    <a href="/videos" style={`text-decoration: none; padding-bottom: 0.5rem; ${Astro.url.pathname.startsWith('/videos') ? 'border-bottom: 2px solid #0066cc; color: #0066cc; font-weight: bold;' : 'color: #666;'}`}>
                        Videos
                    </a>
                    <a href="/glossary" style={`text-decoration: none; padding-bottom: 0.5rem; ${Astro.url.pathname.startsWith('/glossary') ? 'border-bottom: 2px solid #0066cc; color: #0066cc; font-weight: bold;' : 'color: #666;'}`}>
                        Glossary
                    </a>
                </nav>
            </div>
        </header>
        <main>
		    <slot />
        </main>
	</body>
</html>
