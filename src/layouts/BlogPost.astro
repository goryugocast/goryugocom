---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
}

const { title, description, date } = Astro.props;
const tags = Array.isArray(Astro.props.tags) ? Astro.props.tags : [];

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout title={title} description={description} isArticle={true}>
  <article class="prose prose-lg max-w-none">
    <header class="mb-8 not-prose">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{title}</h1>
      {date && (
        <time class="text-sm text-gray-500" datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
      )}
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map(tag => (
            <a href={`/tags/${tag}`} class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded hover:bg-gray-200">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <slot />

    <footer class="mt-12 pt-8 border-t border-gray-200 not-prose">
      <p class="text-gray-600">
        ニュースレターを購読しませんか？
        <a href="https://knowledgestuck.substack.com" class="text-blue-600 hover:underline" target="_blank" rel="noopener">
          Knowledge Stack（Substack）を購読する
        </a>
      </p>
    </footer>
  </article>
</Layout>
