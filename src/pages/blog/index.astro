---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');

// Helper to get title from data or id
const getTitle = (entry: { data: { title?: string }; id: string }) => {
  return entry.data.title || entry.id.replace(/\.md$/, '').split('/').pop() || entry.id;
};

// Sort - posts with date first (by date), then posts without date (alphabetically)
const postsWithDate = blogPosts
  .filter(post => post.data.date)
  .sort((a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime());

const postsWithoutDate = blogPosts
  .filter(post => !post.data.date)
  .sort((a, b) => getTitle(a).localeCompare(getTitle(b), 'ja'));

// Group posts with date by year
const postsByYear = postsWithDate.reduce((acc, post) => {
  const year = new Date(post.data.date!).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof postsWithDate>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', {
    month: 'short',
    day: 'numeric'
  });
};
---

<Layout title="Blog" description="ごりゅごさんのブログ記事一覧">
  <h1 class="text-3xl font-bold mb-8">Blog</h1>

  {years.length > 0 && (
    <div class="space-y-12">
      {years.map(year => (
        <section>
          <h2 class="text-xl font-bold text-gray-400 mb-4">{year}</h2>
          <ul class="space-y-3">
            {postsByYear[year].map(post => (
              <li class="flex items-baseline gap-4">
                <time class="text-sm text-gray-400 w-16 shrink-0" datetime={new Date(post.data.date!).toISOString()}>
                  {formatDate(new Date(post.data.date!))}
                </time>
                <a href={post.data.permalink || `/${post.id}`} class="text-gray-900 hover:text-blue-600">
                  {getTitle(post)}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}

  {postsWithoutDate.length > 0 && (
    <section class={years.length > 0 ? "mt-12" : ""}>
      <h2 class="text-xl font-bold text-gray-400 mb-4">その他</h2>
      <ul class="space-y-3">
        {postsWithoutDate.map(post => (
          <li>
            <a href={post.data.permalink || `/${post.id}`} class="text-gray-900 hover:text-blue-600">
              {getTitle(post)}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {years.length === 0 && postsWithoutDate.length === 0 && (
    <p class="text-gray-500">まだ記事がありません</p>
  )}
</Layout>
