---
import Layout from '../layouts/Layout.astro';
import ArchiveList from '../components/ArchiveList.jsx';
import archiveData from '../data/archive.json';

const articles = archiveData.filter(item => item.type === 'article');
---

<Layout title="Knowledge Stack - Articles">
	<h1 style="text-align: center; margin-bottom: 2rem;">Articles</h1>
    <p style="text-align: center; margin-bottom: 2rem; color: #666;">
        ナレッジスタックの過去記事アーカイブ
    </p>

    <ArchiveList items={articles} client:load />
</Layout>
