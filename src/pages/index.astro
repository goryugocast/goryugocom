---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');
const notes = await getCollection('notes', ({ data }) => data.status !== 'draft');

// Helper to get title from data or id
const getTitle = (entry: { data: { title?: string }; id: string }) => {
  return entry.data.title || entry.id.replace(/\.md$/, '').split('/').pop() || entry.id;
};

// Sort blog posts - with date first, then without date
const sortedPosts = blogPosts
  .sort((a, b) => {
    if (a.data.date && b.data.date) {
      return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    }
    if (a.data.date) return -1;
    if (b.data.date) return 1;
    return getTitle(a).localeCompare(getTitle(b), 'ja');
  })
  .slice(0, 10);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout title="Home" description="ごりゅごさんのブログとノート">
  <section class="hero">
    <h1>goryugo.com</h1>
    <p>ごりゅごさんが面白いと感じたものを書く場所</p>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>最近のブログ記事</h2>
      <a href="/blog">すべて見る →</a>
    </div>
    {sortedPosts.length > 0 ? (
      <ul class="post-list">
        {sortedPosts.map(post => (
          <li>
            <a href={post.data.permalink || `/${post.id}`}>
              <span class="post-title">{getTitle(post)}</span>
              {post.data.date && (
                <time datetime={new Date(post.data.date).toISOString()}>
                  {formatDate(new Date(post.data.date))}
                </time>
              )}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">まだ記事がありません</p>
    )}
  </section>

  <section class="section">
    <div class="section-header">
      <h2>ノート</h2>
      <a href="/notes">すべて見る →</a>
    </div>
    {notes.length > 0 ? (
      <ul class="note-grid">
        {notes.slice(0, 6).map(note => (
          <li>
            <a href={note.data.permalink || `/${note.id}`}>
              {getTitle(note)}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">まだノートがありません</p>
    )}
  </section>
</Layout>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: #6b7280;
    margin: 0;
  }

  .section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .section-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .section-header a {
    font-size: 0.875rem;
    color: #2563eb;
    text-decoration: none;
  }

  .section-header a:hover {
    text-decoration: underline;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 0;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid #f3f4f6;
    text-decoration: none;
    color: inherit;
  }

  .post-list a:hover .post-title {
    color: #2563eb;
  }

  .post-title {
    font-size: 1rem;
    line-height: 1.5;
  }

  .post-list time {
    font-size: 0.875rem;
    color: #9ca3af;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .note-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .note-grid li {
    margin: 0;
  }

  .note-grid a {
    display: block;
    padding: 1rem 1.25rem;
    background: #f9fafb;
    border-radius: 8px;
    text-decoration: none;
    color: #1a1a1a;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .note-grid a:hover {
    background: #f3f4f6;
  }

  .empty {
    color: #9ca3af;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 1.5rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .post-list a {
      flex-direction: column;
      gap: 0.25rem;
    }

    .note-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
